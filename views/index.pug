extends layout

block content
  h1= title
  p Welcome to #{title}'s assignment 10
  <button type="button" class="btn btn-secondary" onclick="reduce()">Sample Button</button>
  <div id="use">take some away</div>

  script.
    let current = 11;
    let quantity = 2;
    function reduce() {
      current = current - quantity
      if (current < 0){
        current = 0;
      }
      document.getElementById("use").innerHTML = 
      `Reduced by ${quantity} to ${current}`;
    }